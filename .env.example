# .env.example — AI News Curation Agent — Environment Variable Reference
# Traces: SRC-073 (secrets from env vars only), SRC-105–SRC-111 (required secrets)
#
# IMPORTANT: Copy this file to .env for local development.
# NEVER commit .env with real values. NEVER put secrets in YAML config files.
# In production, inject secrets via your cloud's secrets manager at runtime.
# (SRC-073, SRC-111)

# ─────────────────────────────────────────────────────────────────────────────
# Required Secrets (SRC-107–SRC-108)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API Key (required for LLM completion and native search)
# Default provider: openai (SRC-057). To use Anthropic, also set ANTHROPIC_API_KEY
# and configure llm.provider: anthropic in your agent YAML.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Twitter/X Bearer Token (required for Twitter influencer signal fetching)
# Minimum recommended tier: Twitter API Basic (SRC-065)
# Auth type: Bearer token (read-only, no OAuth user context required) (SRC-064)
TWITTER_BEARER_TOKEN=AAA...your-twitter-bearer-token-here

# ─────────────────────────────────────────────────────────────────────────────
# Optional Secrets (SRC-109)
# ─────────────────────────────────────────────────────────────────────────────

# External web search API key (optional — only needed if not using OpenAI native search)
# Supported providers: "tavily" | "brave"
# Leave unset to use OpenAI's native web search tool (SRC-060)
# WEB_SEARCH_API_KEY=your-search-api-key-here

# Web search provider selection (default: "tavily" if WEB_SEARCH_API_KEY is set)
# Values: "tavily" | "brave"
# WEB_SEARCH_PROVIDER=tavily

# ─────────────────────────────────────────────────────────────────────────────
# Optional Provider Secrets (SRC-055–SRC-056)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API Key — required when llm.provider: anthropic in agent YAML
# Install the extra: pip install 'ai-news-agent[anthropic]'
# See configs/example-anthropic-agent.yaml for a full example.
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google AI / Vertex AI API Key — required when llm.provider: google in agent YAML
# Install the extra: pip install 'ai-news-agent[google]'
# For Vertex AI: set GOOGLE_APPLICATION_CREDENTIALS instead of GOOGLE_API_KEY
# GOOGLE_API_KEY=AIza-your-google-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler API Authentication (SRC-147 — manual override endpoint)
# ─────────────────────────────────────────────────────────────────────────────

# API key for authenticating POST /api/trigger (manual override endpoint)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SCHEDULER_API_KEY=your-random-32-byte-hex-key

# ─────────────────────────────────────────────────────────────────────────────
# Cloud Deployment Credentials (SRC-110)
# ─────────────────────────────────────────────────────────────────────────────
# Cloud credentials are injected at deploy time via workload identity federation
# (preferred) or service account keys. These are NEVER stored here.
#
# GCP:   GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  (or workload identity)
# AWS:   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY         (or IRSA)
# Azure: AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET (or managed identity)
